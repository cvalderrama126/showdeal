# Application
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Database - PostgreSQL
DATABASE_URL="postgresql://showdeal:your_secure_password@localhost:5432/showdeal?schema=showdeal"

# JWT Authentication
JWT_SECRET="generate-a-random-secret-key-min-32-chars"
JWT_EXPIRES_IN="8h"

# JWT Challenge (OTP)
JWT_CHALLENGE_SECRET="generate-another-random-secret"
JWT_CHALLENGE_EXPIRES_IN="5m"

# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# Optional: Monitoring & Logging
# SENTRY_DSN="https://xxxxx@sentry.io/xxxxx"
# LOG_SERVICE="pino|basic"
